# ====================================
#     DAMAP environment variables
# ====================================

# ---------------------------
#   General configuration
# ---------------------------

# Sets the frontend mode, should always be PROD for production environments.
# Allowed values:
#   - DEV
#   - PROD
DAMAP_ENV=DEV

# Sets the HTML title of the frontend
DAMAP_TENANT_AWARE_TITLE="DAMAP Tool"

# Comma-separated list of allowed browser origins for CORS.
# This should match your external DAMAP URL.
# NOTE: No trailing slash!
DAMAP_QUARKUS_HTTP_CORS_ORIGINS=http://your.domain1.com,https://your.domain2.com

# Comma-separated profiles, defaults to prod if left empty.
DAMAP_QUARKUS_PROFILE=

# ---------------------------
#   Database configuration
# ---------------------------

# Host of the database.
# For production with the bundled database, use damap-db.
# For development, leave this unset or use the Compose service name, e.g. postgres-db or oracle-db.
# For an external database, set this to the database host, e.g. your domain name or an IP address.
DAMAP_DB_HOST=damap-db

# Type of the database.
# The Docker entrypoint supports only postgresql and oracle.
# It uses this value to build the Quarkus JDBC URL automatically.
# For Oracle, it also sets the JDBC driver and Hibernate dialect.
# Allowed values:
#   - postgresql
#   - oracle
DAMAP_DB_KIND=postgresql

# Name of the database.
# Used also as POSTGRES_DB when deploying with the "with_db" profile.
# For the Oracle development container, use FREEPDB1.
DAMAP_DB_NAME=damap

# Password for the database user. Used also as POSTGRES_PASSWORD when deploying with the "with_db" profile.
DAMAP_DB_PASSWORD=pw4damap

# Port of the database.
# Defaults used by the Docker entrypoint are 5432 for PostgreSQL and 1521 for Oracle.
DAMAP_DB_PORT=5432

# Username for the database connection. Used also as POSTGRES_USER when deploying with the "with_db" profile.
DAMAP_DB_USERNAME=damap

# ---------------------------
#    OIDC Authentication
# ---------------------------

# Role name used to identify DAMAP super admins.
# If DAMAP is locally deployed and the variable is not set to damap-super-admin, ADMIN_ROLE constant in the
# DefaultProfile test profile needs to be changed accordingly, otherwise the tests will fail.
DAMAP_AUTH_ADMIN_ROLE_NAME='Damap Admin'

# The OIDC claim that holds the user's affiliations.
DAMAP_AUTH_AFFILIATIONS_CLAIM=affiliation

# The OIDC claim that holds the user's email.
DAMAP_AUTH_EMAIL_CLAIM=email

# The OIDC claim that holds the user's family name.
DAMAP_AUTH_FAMILY_NAME_CLAIM=family_name

# The OIDC claim that holds the user's given name.
DAMAP_AUTH_GIVEN_NAME_CLAIM=given_name

# The OIDC claim that holds the user's full name.
DAMAP_AUTH_NAME_CLAIM=name

# Scopes to request during login
DAMAP_AUTH_SCOPE="openid profile email offline_access microprofile-jwt roles personID"

# The OIDC claim to use as a user ID.
DAMAP_AUTH_USER_ID_CLAIM=personID

# The OIDC claim path that will hold your DAMAP roles in the access token
# Also accepts paths, e.g. "realm_access/roles"
DAMAP_AUTH_USER_ROLES_CLAIM_PATH=realm_access/roles

# Configures the OIDC realm the DAMAP backend should query to verify authentication.
DAMAP_QUARKUS_OIDC_AUTH_SERVER_URL=http://keycloak:8080/realms/damap

# Client ID as configured in the OIDC Server
DAMAP_QUARKUS_OIDC_CLIENT_ID=damap

# Configures the OIDC URL the frontend should send users to in order to log in. This is typically the same
# as DAMAP_QUARKUS_OIDC_AUTH_SERVER_URL, but may differ if the backend can access the OIDC server over a non-public network
DAMAP_QUARKUS_OIDC_TOKEN_ISSUER=http://localhost:8087/realms/damap


# ----------------------------
#   Person/Project services
# ----------------------------

# Sets the project service used, should be set to elsevier-pure only when pure integration is used.
# Allowed values:
#   - default (mock service or custom, if provided)
#   - disabled (no connected project service)
#   - elsevier-pure
DAMAP_TENANT_AWARE_PROJECT_SERVICE=default

# DISPLAY_TEXT: The text shown in the frontend to allow users to switch between person services.
# QUERY_VALUE: Should uniquely identify the service.
# CLASS_NAME: Which java class should be used for the service implementation. Set to:
# "org.damap.base.integration.orcid.ORCIDPersonServiceImpl" for ORCID
# "org.damap.base.integration.pure.PurePersonService" for Pure
# or to your custom class, if you use a custom integration.
# To add further mappings, copy the three environment variable group below and increment the indexes.
# NOTE: the  two underscores `0__` are on purpose - these are necessary due to how SmallRye processes env variables.
DAMAP_TENANT_AWARE_PERSON_SERVICES_0__DISPLAY_TEXT=University
DAMAP_TENANT_AWARE_PERSON_SERVICES_0__QUERY_VALUE=UNIVERSITY
DAMAP_TENANT_AWARE_PERSON_SERVICES_0__CLASS_NAME=org.damap.base.integration.mock.MockUniversityPersonServiceImpl
DAMAP_TENANT_AWARE_PERSON_SERVICES_1__DISPLAY_TEXT=ORCID
DAMAP_TENANT_AWARE_PERSON_SERVICES_1__QUERY_VALUE=ORCID
DAMAP_TENANT_AWARE_PERSON_SERVICES_1__CLASS_NAME=org.damap.base.integration.orcid.ORCIDPersonServiceImpl

# ---------------------------
#            REST
# ---------------------------

# URL for Gotenberg, used for document export/previews.
DAMAP_REST_GOTENBERG_MP_REST_URL=http://gotenberg:3000

# ---------------------------
#           Fields
# ---------------------------

# Enables input field for short ethical report description
DAMAP_TENANT_AWARE_FIELDS_ETHICAL_REPORT_ENABLED=true

# ---------------------------
#        Elsevier PURE       
# ---------------------------

# API key used to authenticate over the PURE API, only relevant when ELSEVIER_PURE_BACKEND is set to http
DAMAP_TENANT_AWARE_ELSEVIER_PURE_API_KEY="your API key here"

# Configures if data should be fetched over http or from local files - should always be http for PROD:
# Allowed values:
#   - file
#   - http
DAMAP_TENANT_AWARE_ELSEVIER_PURE_BACKEND=http

# The following settings map Pure classification URIs to DAMAP properties.
# Pure classification URIs start with /dk/atira/pure, but are otherwise specific to the institutional setup in Pure.

# How Pure project contributor classifications map to DAMAP.
# To add further mappings, copy the two environment variables below and increment the indexes from 0 to 1.
# NOTE: the  two underscores `0__` are on purpose - these are necessary due to how SmallRye processes env variables.
DAMAP_TENANT_AWARE_ELSEVIER_PURE_CONTRIBUTOR_ROLE_CLASSIFICATIONS_0__CONTRIBUTOR_ROLE=PROJECT_MEMBER
DAMAP_TENANT_AWARE_ELSEVIER_PURE_CONTRIBUTOR_ROLE_CLASSIFICATIONS_0__PURE_ROLE_URI=/dk/atira/pure/member

# The project description field DAMAP should use.
DAMAP_TENANT_AWARE_ELSEVIER_PURE_DESCRIPTION_CLASSIFICATION=/dk/atira/pure/projectdescription

# URL to fetch data from, only relevant when ELSEVIER_PURE_BACKEND is set to http.
DAMAP_TENANT_AWARE_ELSEVIER_PURE_ENDPOINT_URL="https://your-pure-instance.elsevierpure.com/ws/api"

# Location of persons file, only relevant when ELSEVIER_PURE_BACKEND is set to file.
DAMAP_TENANT_AWARE_ELSEVIER_PURE_PERSONS_FILE="file:///path/to/persons.json"

# Which Pure classification should be read as the project lead.
DAMAP_TENANT_AWARE_ELSEVIER_PURE_PROJECT_LEAD_ROLE_CLASSIFICATION=/dk/atira/pure/projectlead

# Location of projects file, only relevant when ELSEVIER_PURE_BACKEND is set to file.
DAMAP_TENANT_AWARE_ELSEVIER_PURE_PROJECTS_FILE="file:///path/to/projects.json"


# ====================================
#   Keycloak environment variables
# ====================================

# In production, these will take effect when deploying with the "with_keycloak" profile.
# When deploying without this profile, these variables will not have any effect, and you can safely ignore them.

# Admin credentials for Keycloak:
KC_ADMIN_PASSWORD=admin
KC_ADMIN_USERNAME=admin

# Keycloak database settings:
KC_DB_DATABASE=keycloak
KC_DB_HOST=keycloak-db
KC_DB_PASSWORD=keycloak
KC_DB_PORT=5432
KC_DB_USERNAME=keycloak


# ====================================
#         PRODUCTION SETTINGS
# ====================================

# These additional settings will only take effect when deploying with the -f docker-compose.prod.yaml flag.
# When using the default docker compose file, these variables will not have any effect, and you can safely ignore them.

# Domain name of the DAMAP instance. Used to:
# - set the Keycloak base URL via an environment variable.
# - populate URLs in the JSON file used for importing the DAMAP realm.
# If you are using an external OIDC provider, you can safely ignore this.
# NOTE: No protocol (http/https) and no trailing slash!
DAMAP_HOSTNAME=your.domain.com

# Path on the host machine where the database data should be stored when deploying with the "with_db" profile.
# A subdirectory will be automatically created named "damap-db".
DAMAP_DB_DATA_HOST_PATH=./data

# Version of DAMAP to deploy. This should match the version of the docker images you have built or pulled.
DAMAP_VERSION=5.0.0

# Path on the host machine where the Keycloak database data should be stored when deploying with the "with_keycloak_db" profile.
# A subdirectory will be automatically created named "keycloak-db".
KC_DB_DATA_HOST_PATH=./data

# ---------------------------
#       Proxy settings
# ---------------------------

# Path on the host machine where the proxy logs should be stored.
PROXY_LOGS_HOST_PATH=logs

# IMPORTANT: For production, you will have to set the following variables explicitly (otherwise the containers will fail to start):
# - DAMAP_AUTH_USER_ROLES_CLAIM_PATH
# - DAMAP_DB_HOST
# - DAMAP_DB_NAME
# - DAMAP_DB_PASSWORD
# - DAMAP_DB_USERNAME
# - DAMAP_HOSTNAME
# - DAMAP_QUARKUS_HTTP_CORS_ORIGINS
# - DAMAP_QUARKUS_OIDC_AUTH_SERVER_URL
# - DAMAP_QUARKUS_OIDC_CLIENT_ID
# - DAMAP_QUARKUS_OIDC_TOKEN_ISSUER
# - PROXY_LOGS_HOST_PATH

# Additionally, if you are deploying with the "with_db" profile, you will also have to set the following variable explicitly:
# - DAMAP_DB_DATA_HOST_PATH

# If you are deploying with the "with_keycloak" profile, you will also have to set the following variables explicitly:
# - KC_ADMIN_PASSWORD
# - KC_ADMIN_USERNAME
# - KC_DB_PASSWORD
# - KC_DB_DATABASE
# - KC_DB_USERNAME

# If you are deploying with the "with_keycloak_db" profile, you will also have to set the following variable explicitly:
# - KC_DB_DATA_HOST_PATH
